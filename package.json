{
  "name": "@ricardodevries/mcp-claude-memory",
  "version": "0.1.0",
  "description": "MCP server providing persistent memory with context layers, semantic search, and session briefings for Claude Code",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=24.0.0"
  },
  "bin": {
    "mcp-claude-memory": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "author": "Ricardo de Vries",
  "license": "MIT",
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "better-sqlite3": "^12.10.0",
    "sqlite-vec": "^0.1.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.0.0",
    "prettier": "3.8.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "allowScripts": {
    "better-sqlite3@12.10.0": true,
    "fsevents@2.3.3": true,
    "onnxruntime-node@1.24.3": true,
    "protobufjs@7.6.2": true,
    "sharp@0.34.5": true
  }
}
